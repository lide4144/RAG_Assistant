# RAG GPT Environment Configuration

# =============================================================================
# SiliconFlow API (Required for LLM and Embedding)
# =============================================================================
SILICONFLOW_API_KEY=your-siliconflow-api-key-here

# =============================================================================
# Qdrant Vector Database Configuration
# =============================================================================
# Option 1: Qdrant Cloud (Recommended for development)
# Get your URL and API Key from https://cloud.qdrant.io
QDRANT_URL=https://your-cluster.cloud.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key-here

# Option 2: Local Qdrant (Docker)
# Uncomment these and comment out the cloud options above
# QDRANT_HOST=localhost
# QDRANT_PORT=6333
# QDRANT_API_KEY=  # Leave empty for local instance without auth

# =============================================================================
# Optional: Other API Keys
# =============================================================================
# OPENAI_API_KEY=your-openai-api-key-here
# ANTHROPIC_API_KEY=your-anthropic-api-key-here

# =============================================================================
# Optional: Development Settings
# =============================================================================
# LOG_LEVEL=INFO
# DEBUG=true